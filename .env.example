# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skillhub"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # generate: openssl rand -base64 32

# Google OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=""

# Resend (email) — get from resend.com
RESEND_API_KEY=""

# Allowed Google Workspace domain (hd restriction)
ALLOWED_DOMAIN="yourcompany.com"

# Comma-separated list of emails that get isAdmin=true on first login
ADMIN_EMAILS="you@yourcompany.com"
