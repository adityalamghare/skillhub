generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  avatar     String?
  department String?
  isAdmin    Boolean  @default(false)
  emailSubscribed Boolean @default(true) // receives the org-wide featured email; users can opt out
  createdAt  DateTime @default(now())

  skills    Skill[]
  votes     Vote[]
  comments  Comment[]
  copies    CopyEvent[]
  features  Feature[]  @relation("FeatureSelectedBy")
  tokens    PersonalAccessToken[]
  notificationViews NotificationView[]
}

model Skill {
  id          String   @id @default(cuid())
  title       String
  description String
  content     String   // raw .md
  toolType    ToolType
  tags        String[]
  authorId    String
  hidden      Boolean  @default(false)
  sourceKey   String?  // authorId:origin:relativePath — unique per author, set on bulk import
  contentHash String?  // sha256 of raw content — used for import dedup
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User        @relation(fields: [authorId], references: [id])
  votes     Vote[]
  comments  Comment[]
  copies    CopyEvent[]
  features  Feature[]

  @@unique([authorId, sourceKey])
}

model Vote {
  id        String   @id @default(cuid())
  skillId   String
  userId    String
  createdAt DateTime @default(now())

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([skillId, userId])
}

model Comment {
  id        String    @id @default(cuid())
  skillId   String
  userId    String
  body      String
  parentId  String?
  hidden    Boolean   @default(false)
  createdAt DateTime  @default(now())
  editedAt  DateTime?

  skill    Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")
}

model CopyEvent {
  id        String   @id @default(cuid())
  skillId   String
  userId    String
  createdAt DateTime @default(now())

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([skillId, userId])
}

model Feature {
  id           String        @id @default(cuid())
  skillId      String
  period       String        // YYYY-MM
  type         FeatureType
  creatorNote  String?
  status       FeatureStatus @default(pending_note)
  selectedAt   DateTime      @default(now())
  sentAt       DateTime?
  selectedById String

  skill        Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  selectedBy   User  @relation("FeatureSelectedBy", fields: [selectedById], references: [id])
}

// Per-recipient read state for in-product notifications.
// Notification *content* is derived from Vote/CopyEvent/Comment; this table only
// records when a user last viewed a given (skill, kind) notification group.
// A group is "unread" when its latest activity is newer than seenAt (or no row exists).
model NotificationView {
  id      String   @id @default(cuid())
  userId  String
  skillId String
  kind    String   // "upvote" | "copy" | "comment"
  seenAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId, kind])
}

model PersonalAccessToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  tokenHash   String    @unique // sha256 of the raw token
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Admin-tunable config stored in DB (key/value pairs)
// Keys: SCORE_WEIGHT_COPIES, SCORE_WEIGHT_COMMENTS, SCORE_WEIGHT_UNIQUE_COMMENTERS,
//       SCORE_WEIGHT_UPVOTES, SCORE_MIN_COPIERS, FEATURED_SCORE_WINDOW,
//       FEATURED_RECIPIENT_LIST (comma-sep group/distribution emails, added on top of subscribed users)
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum ToolType {
  Claude
  Cursor
  Both
}

enum FeatureType {
  auto
  manual
}

enum FeatureStatus {
  pending_note
  ready
  sent
}
